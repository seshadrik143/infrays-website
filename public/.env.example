# NodePulse — environment variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Version ────────────────────────────────────────────────────────────────────
# Pin to a specific release tag, or use 'latest' for the most recent build.
NODEPULSE_VERSION=latest

# ── Ports ─────────────────────────────────────────────────────────────────────
SERVER_PORT=8080          # NodePulse server API
DASHBOARD_PORT=3000       # Web UI
VM_PORT=8428              # VictoriaMetrics (internal — change only if there's a conflict)

# ── VictoriaMetrics ───────────────────────────────────────────────────────────
VM_RETENTION=30d          # how long to keep metrics (e.g. 30d, 6m, 1y)

# ── PostgreSQL (only needed if using --profile postgres) ─────────────────────
POSTGRES_PASSWORD=change_me_in_production
